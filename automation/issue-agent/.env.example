REPO=ehdgks0627/crypto-scanner
BASE_BRANCH=main

# Required for GitHub API access and push permission.
GH_TOKEN=

# Default LLM runner uses the host Codex CLI login mounted from CODEX_AUTH_SOURCE.
CODEX_MODEL=
CODEX_AUTH_SOURCE=${HOME}/.codex/auth.json

# Pick one open issue automatically, or force a specific issue number.
# RUN_ONCE=0 keeps the container alive and polls forever.
RUN_ONCE=0
POLL_INTERVAL_SECONDS=300
DRY_RUN=0
DRY_RUN_LIMIT=10
ISSUE_NUMBER=
ISSUE_SEARCH=is:issue is:open -label:ai-in-progress -label:ai-failed sort:created-asc

# direct pushes to BASE_BRANCH. branch pushes to ai/issue-* and can optionally create a PR.
PUSH_MODE=direct
CREATE_PR=0
AUTO_CLOSE=1

# Optional extra verification after the LLM commits.
VERIFY_COMMAND=

# Remote deployment over SSH. The default matches `ssh pqc` and Docker compose.
AUTO_DEPLOY=1
SSH_DEPLOY_HOST=pqc
REMOTE_REPO_DIR=/opt/crypto-scanner
REMOTE_DEPLOY_COMMAND=if [ ! -d .git ]; then git init; fi && (git remote get-url origin >/dev/null 2>&1 || git remote add origin https://github.com/ehdgks0627/crypto-scanner.git) && git fetch origin main && git reset --hard origin/main && sudo -n docker compose -f system/docker-compose.yml up -d --build

# Compose mounts only these SSH files, not the whole ~/.ssh directory.
SSH_CONFIG_SOURCE=${HOME}/.ssh/config
SSH_KEY_SOURCE=${HOME}/.ssh/crypto_scanner_issue_agent_ed25519
SSH_KNOWN_HOSTS_SOURCE=${HOME}/.ssh/known_hosts

# Optional alternative when you do not mount SSH files into the container.
SSH_PRIVATE_KEY=
SSH_KNOWN_HOSTS=
