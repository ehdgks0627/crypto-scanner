server {
  listen ${SERVICE_PORT} ssl;
  server_name ${SERVICE_HOSTNAME};

  ssl_protocols ${TLS_PROTOCOLS};
  ssl_ciphers DEFAULT:@SECLEVEL=0;
  ssl_conf_command CipherString DEFAULT:@SECLEVEL=0;
  ssl_certificate /etc/testbed/certs/service/server.crt;
  ssl_certificate_key /etc/testbed/certs/service/server.key;

  add_header X-Testbed-Service "${SERVICE_KIND}" always;

  location / {
    default_type text/plain;
    return 200 "${SERVICE_HOSTNAME} ${SERVICE_KIND} fixture\n";
  }
}
