# Copy to `.env` and set BOOTSTRAP_TOKEN to the same value as the system stack.
BACKEND_URL=http://host.docker.internal:8000
# Must match system backend AGENT_BOOTSTRAP_TOKEN.
BOOTSTRAP_TOKEN=replace-with-system-agent-bootstrap-token

AGENT_LISTEN=0.0.0.0:9100
AGENT_LOG_LEVEL=INFO
# Hostname/IP registered in agent_url for backend/worker pull calls.
# Use host.docker.internal only when the backend/worker also runs in Docker and
# TESTBED_BIND_ADDR is set to 0.0.0.0.
AGENT_PUBLIC_HOST=127.0.0.1

# Ports are bound to loopback by default to avoid exposing intentionally weak
# testbed services on the LAN. Set 0.0.0.0 only for a dockerized system stack
# that must reach host-published ports via host.docker.internal.
TESTBED_BIND_ADDR=127.0.0.1
DNS_PORT_HOST=5353

WEB_HTTPS_PORT=4430
WEB_AGENT_PORT=9101
PQC_TLS_PORT=4431
SSH_PORT=2222
SSH_AGENT_PORT=9102
MQTT_TLS_PORT=8883
IPSEC_IKE_PORT=5000
IPSEC_NATT_PORT=45000
MAIL_SMTP_PORT=2525
MAIL_SMTPS_PORT=4465
MAIL_SUBMISSION_PORT=5587
MAIL_IMAPS_PORT=9993
MAIL_POP3S_PORT=9995
DB_PORT=54320
DB_AGENT_PORT=9103

POSTGRES_DB=pqc_testbed
POSTGRES_USER=pqc
POSTGRES_PASSWORD=replace-with-testbed-db-password
IPSEC_PSK=replace-with-testbed-ipsec-psk

CERT_VALIDITY_DAYS=365
CERT_NEAR_EXPIRY_DAYS=15
