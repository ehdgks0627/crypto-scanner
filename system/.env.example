DJANGO_SECRET_KEY=replace-with-demo-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
AGENT_BOOTSTRAP_TOKEN=replace-with-agent-bootstrap-token
DATABASE_URL=sqlite:////data/db.sqlite3
LOAD_INITIAL_TARGETS=1
WEB_PORT=80
WEB_HTTPS_PORT=443
TLS_CERT_CN=localhost
TLS_CERT_SAN=DNS:localhost,IP:127.0.0.1
QUALITATIVE_LLM_PROVIDER=mock-rulebook
# QUALITATIVE_LLM_PROVIDER=openai-compatible
# QUALITATIVE_LLM_MODEL=
# QUALITATIVE_LLM_API_KEY=
# QUALITATIVE_LLM_BASE_URL=https://api.openai.com/v1
# QUALITATIVE_LLM_TIMEOUT_SECONDS=30
